-- INFINITY UI (VERSÃO AVANÇADA - SISTEMA DE TEMA PROFISSIONAL)
-- Foco: controle TOTAL de cores igual/better que Rayfield

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local InfinityUI = {}
InfinityUI.__index = InfinityUI

-- SISTEMA DE TEMA DINÂMICO
InfinityUI.Theme = {
    Background = Color3.fromRGB(20,20,25),
    Secondary = Color3.fromRGB(30,30,35),
    Accent = Color3.fromRGB(140,70,255),
    Text = Color3.fromRGB(255,255,255),
    SubText = Color3.fromRGB(180,180,180)
}

InfinityUI.Objects = {}

function InfinityUI:SetTheme(newTheme)
    for k,v in pairs(newTheme) do
        self.Theme[k] = v
    end

    -- Atualiza TODOS os objetos automaticamente
    for _,obj in pairs(self.Objects) do
        if obj.Type == "Background" then
            obj.Instance.BackgroundColor3 = self.Theme.Background
        elseif obj.Type == "Secondary" then
            obj.Instance.BackgroundColor3 = self.Theme.Secondary
        elseif obj.Type == "Accent" then
            obj.Instance.BackgroundColor3 = self.Theme.Accent
        elseif obj.Type == "Text" then
            obj.Instance.TextColor3 = self.Theme.Text
        end
    end
end

function InfinityUI:Track(instance, type)
    table.insert(self.Objects, {
        Instance = instance,
        Type = type
    })
end

function InfinityUI:CreateWindow(title)
    local self = setmetatable({}, InfinityUI)

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Parent = game.CoreGui

    local Main = Instance.new("Frame")
    Main.Size = UDim2.new(0, 520, 0, 320)
    Main.Position = UDim2.new(0.5, -260, 0.5, -160)
    Main.BackgroundColor3 = self.Theme.Background
    Main.Parent = ScreenGui
    self:Track(Main, "Background")

    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 130, 1, 0)
    Sidebar.BackgroundColor3 = self.Theme.Secondary
    Sidebar.Parent = Main
    self:Track(Sidebar, "Secondary")

    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)

    local SidebarLayout = Instance.new("UIListLayout", Sidebar)
    SidebarLayout.Padding = UDim.new(0, 6)

    local Content = Instance.new("Frame")
    Content.Size = UDim2.new(1, -130, 1, 0)
    Content.Position = UDim2.new(0, 130, 0, 0)
    Content.BackgroundTransparency = 1
    Content.Parent = Main

    local Pages = {}

    function self:CreateTab(name)
        local Button = Instance.new("TextButton")
        Button.Size = UDim2.new(1, -10, 0, 32)
        Button.Text = name
        Button.BackgroundColor3 = self.Theme.Secondary
        Button.TextColor3 = self.Theme.Text
        Button.Parent = Sidebar

        self:Track(Button, "Secondary")
        self:Track(Button, "Text")

        Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 8)

        local Page = Instance.new("Frame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.Parent = Content

        local Layout = Instance.new("UIListLayout", Page)
        Layout.Padding = UDim.new(0, 8)

        Button.MouseButton1Click:Connect(function()
            for _,v in pairs(Content:GetChildren()) do
                if v:IsA("Frame") then
                    v.Visible = false
                end
            end
            Page.Visible = true
        end)

        Button.MouseEnter:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.2), {
                BackgroundColor3 = self.Theme.Accent
            }):Play()
        end)

        Button.MouseLeave:Connect(function()
            TweenService:Create(Button, TweenInfo.new(0.2), {
                BackgroundColor3 = self.Theme.Secondary
            }):Play()
        end)

        local Tab = {}

        function Tab:CreateButton(text, callback)
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, -10, 0, 36)
            Btn.Text = text
            Btn.BackgroundColor3 = self.Theme.Secondary
            Btn.TextColor3 = self.Theme.Text
            Btn.Parent = Page

            InfinityUI:Track(Btn, "Secondary")
            InfinityUI:Track(Btn, "Text")

            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)

            Btn.MouseButton1Click:Connect(callback)
        end

        function Tab:CreateToggle(text, callback)
            local state = false

            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, -10, 0, 36)
            Btn.Text = text .. " : OFF"
            Btn.BackgroundColor3 = self.Theme.Secondary
            Btn.TextColor3 = self.Theme.Text
            Btn.Parent = Page

            InfinityUI:Track(Btn, "Secondary")
            InfinityUI:Track(Btn, "Text")

            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)

            Btn.MouseButton1Click:Connect(function()
                state = not state
                Btn.Text = text .. " : " .. (state and "ON" or "OFF")
                callback(state)
            end)
        end

        return Tab
    end

    return self
end

return InfinityUI
