local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")

local InfinityUI = {}
InfinityUI.__index = InfinityUI

-- Tema (pode mudar depois com :SetTheme)
InfinityUI.Theme = {
    Background = Color3.fromRGB(18, 18, 22),
    Secondary = Color3.fromRGB(28, 28, 32),
    Accent = Color3.fromRGB(140, 70, 255),
    Text = Color3.fromRGB(255, 255, 255),
    Stroke = Color3.fromRGB(60, 60, 70)
}

InfinityUI.Registry = {}

function InfinityUI:Track(obj, type)
    table.insert(self.Registry, {Instance = obj, Type = type})
end

function InfinityUI:SetTheme(newTheme)
    for k, v in pairs(newTheme) do
        self.Theme[k] = v
    end
    for _, v in pairs(self.Registry) do
        if v.Type == "BG" then v.Instance.BackgroundColor3 = self.Theme.Background end
        if v.Type == "SEC" then v.Instance.BackgroundColor3 = self.Theme.Secondary end
        if v.Type == "ACC" then v.Instance.BackgroundColor3 = self.Theme.Accent end
        if v.Type == "TXT" then v.Instance.TextColor3 = self.Theme.Text end
        if v.Type == "STROKE" then v.Instance.Color = self.Theme.Stroke end
    end
end

function InfinityUI:CreateWindow(config)
    local self = setmetatable({}, InfinityUI)
    local title = config.Title or "Infinity UI"

    local gui = Instance.new("ScreenGui")
    gui.Parent = game.CoreGui
    gui.ResetOnSpawn = false

    local blur = Instance.new("BlurEffect", Lighting)
    blur.Size = 15

    -- Main Frame
    local main = Instance.new("Frame", gui)
    main.Size = UDim2.new(0, 600, 0, 400)
    main.Position = UDim2.new(0.5, -300, 0.5, -200)
    main.BackgroundColor3 = self.Theme.Background
    main.BorderSizePixel = 0
    self:Track(main, "BG")
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 14)
    Instance.new("UIStroke", main).Color = self.Theme.Stroke
    Instance.new("UIStroke", main).Transparency = 0.7

    -- Topbar
    local topbar = Instance.new("Frame", main)
    topbar.Size = UDim2.new(1, 0, 0, 40)
    topbar.BackgroundColor3 = self.Theme.Secondary
    self:Track(topbar, "SEC")
    Instance.new("UICorner", topbar).CornerRadius = UDim.new(0, 14)
    Instance.new("UIStroke", topbar).Color = self.Theme.Stroke

    local titleLabel = Instance.new("TextLabel", topbar)
    titleLabel.Size = UDim2.new(1, -100, 1, 0)
    titleLabel.Position = UDim2.new(0, 15, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = self.Theme.Text
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 16
    self:Track(titleLabel, "TXT")

    -- Drag
    local dragging = false
    local dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    topbar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Close e Minimize
    local closeBtn = Instance.new("TextButton", topbar)
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.new(1, 0, 0)
    closeBtn.BackgroundTransparency = 1
    closeBtn.MouseButton1Click:Connect(function()
        blur:Destroy()
        gui:Destroy()
    end)

    local minBtn = Instance.new("TextButton", topbar)
    minBtn.Size = UDim2.new(0, 30, 0, 30)
    minBtn.Position = UDim2.new(1, -70, 0, 5)
    minBtn.Text = "─"
    minBtn.TextColor3 = self.Theme.Text
    minBtn.BackgroundTransparency = 1
    minBtn.MouseButton1Click:Connect(function()
        main.Visible = false
        local icon = Instance.new("TextButton", gui)
        icon.Size = UDim2.new(0, 60, 0, 60)
        icon.Position = UDim2.new(0, 20, 0.5, -30)
        icon.Text = "∞"
        icon.TextColor3 = self.Theme.Accent
        icon.BackgroundTransparency = 0.3
        icon.MouseButton1Click:Connect(function()
            main.Visible = true
            icon:Destroy()
        end)
    end)

    -- Sidebar
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 160, 1, -40)
    sidebar.Position = UDim2.new(0, 0, 0, 40)
    sidebar.BackgroundColor3 = self.Theme.Secondary
    self:Track(sidebar, "SEC")

    local sidebarLayout = Instance.new("UIListLayout", sidebar)
    sidebarLayout.Padding = UDim.new(0, 4)
    sidebarLayout.SortOrder = Enum.SortOrder.LayoutOrder

    -- Content Area
    local content = Instance.new("ScrollingFrame", main)
    content.Size = UDim2.new(1, -160, 1, -40)
    content.Position = UDim2.new(0, 160, 0, 40)
    content.BackgroundTransparency = 1
    content.ScrollBarThickness = 6
    content.ScrollBarImageColor3 = self.Theme.Accent
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.CanvasSize = UDim2.new(0, 0, 0, 0)

    local contentLayout = Instance.new("UIListLayout", content)
    contentLayout.Padding = UDim.new(0, 8)
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local firstTab = true

    function self:CreateTab(tabName)
        local tabButton = Instance.new("TextButton", sidebar)
        tabButton.Size = UDim2.new(1, -10, 0, 40)
        tabButton.Position = UDim2.new(0, 5, 0, 0)
        tabButton.Text = tabName
        tabButton.BackgroundColor3 = self.Theme.Secondary
        tabButton.TextColor3 = self.Theme.Text
        tabButton.Font = Enum.Font.GothamSemibold
        self:Track(tabButton, "SEC")

        local tabPage = Instance.new("Frame", content)
        tabPage.BackgroundTransparency = 1
        tabPage.Visible = firstTab
        tabPage.Size = UDim2.new(1, 0, 0, 0)
        tabPage.AutomaticSize = Enum.AutomaticSize.Y
        firstTab = false

        tabButton.MouseButton1Click:Connect(function()
            for _, child in content:GetChildren() do
                if child:IsA("Frame") then child.Visible = false end
            end
            tabPage.Visible = true
        end)

        local Tab = {}

        function Tab:CreateButton(cfg)
            local btn = Instance.new("TextButton", tabPage)
            btn.Size = UDim2.new(1, -10, 0, 45)
            btn.BackgroundColor3 = self.Theme.Accent
            btn.Text = cfg.Name or "Button"
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.GothamBold
            self:Track(btn, "ACC")
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

            btn.MouseButton1Click:Connect(cfg.Callback or function() end)

            -- Hover effect
            btn.MouseEnter:Connect(function()
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Accent:Lerp(Color3.new(1,1,1), 0.2)}):Play()
            end)
            btn.MouseLeave:Connect(function()
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Accent}):Play()
            end)
        end

        function Tab:CreateToggle(cfg)
            local toggled = cfg.Default or false
            local toggleFrame = Instance.new("Frame", tabPage)
            toggleFrame.Size = UDim2.new(1, -10, 0, 45)
            toggleFrame.BackgroundColor3 = self.Theme.Secondary
            Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(0, 10)

            local label = Instance.new("TextLabel", toggleFrame)
            label.Size = UDim2.new(0.7, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = cfg.Name or "Toggle"
            label.TextColor3 = self.Theme.Text
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Position = UDim2.new(0, 15, 0, 0)

            local switch = Instance.new("Frame", toggleFrame)
            switch.Size = UDim2.new(0, 50, 0, 25)
            switch.Position = UDim2.new(1, -65, 0.5, -12.5)
            switch.BackgroundColor3 = toggled and self.Theme.Accent or Color3.fromRGB(60,60,70)
            Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)

            local knob = Instance.new("Frame", switch)
            knob.Size = UDim2.new(0, 20, 0, 20)
            knob.Position = toggled and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
            knob.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

            local function updateToggle()
                TweenService:Create(switch, TweenInfo.new(0.25), {BackgroundColor3 = toggled and self.Theme.Accent or Color3.fromRGB(60,60,70)}):Play()
                TweenService:Create(knob, TweenInfo.new(0.25), {Position = toggled and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)}):Play()
                if cfg.Callback then cfg.Callback(toggled) end
            end

            toggleFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    toggled = not toggled
                    updateToggle()
                end
            end)
        end

        function Tab:CreateSlider(cfg)
            local value = cfg.Default or cfg.Min
            local sliderFrame = Instance.new("Frame", tabPage)
            sliderFrame.Size = UDim2.new(1, -10, 0, 60)
            sliderFrame.BackgroundColor3 = self.Theme.Secondary
            Instance.new("UICorner", sliderFrame).CornerRadius = UDim.new(0, 10)

            local label = Instance.new("TextLabel", sliderFrame)
            label.Size = UDim2.new(1, 0, 0, 20)
            label.BackgroundTransparency = 1
            label.Text = (cfg.Name or "Slider") .. ": " .. value
            label.TextColor3 = self.Theme.Text

            local bar = Instance.new("Frame", sliderFrame)
            bar.Size = UDim2.new(1, -20, 0, 8)
            bar.Position = UDim2.new(0, 10, 0, 35)
            bar.BackgroundColor3 = Color3.fromRGB(60,60,70)
            Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

            local fill = Instance.new("Frame", bar)
            fill.Size = UDim2.new(0, 0, 1, 0)
            fill.BackgroundColor3 = self.Theme.Accent
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

            local function updateSlider()
                local percent = (value - cfg.Min) / (cfg.Max - cfg.Min)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                label.Text = (cfg.Name or "Slider") .. ": " .. math.floor(value)
                if cfg.Callback then cfg.Callback(value) end
            end

            bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local connection
                    connection = UserInputService.InputChanged:Connect(function(move)
                        if move.UserInputType == Enum.UserInputType.MouseMovement then
                            local rel = math.clamp((move.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                            value = cfg.Min + (cfg.Max - cfg.Min) * rel
                            updateSlider()
                        end
                    end)
                    local ended = UserInputService.InputEnded:Connect(function()
                        connection:Disconnect()
                        ended:Disconnect()
                    end)
                end
            end)

            updateSlider()
        end

        -- Outros elementos (Label, Section, Dropdown, etc.) podem ser adicionados da mesma forma
        -- Quer que eu adicione mais? É só pedir!

        return Tab
    end

    function self:Notify(text)
        local notif = Instance.new("TextLabel", gui)
        notif.Size = UDim2.new(0, 250, 0, 50)
        notif.Position = UDim2.new(1, -270, 1, -70)
        notif.BackgroundColor3 = self.Theme.Secondary
        notif.Text = text
        notif.TextColor3 = self.Theme.Text
        Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)

        TweenService:Create(notif, TweenInfo.new(0.5), {Position = UDim2.new(1, -270, 1, -120)}):Play()
        task.wait(3)
        TweenService:Create(notif, TweenInfo.new(0.5), {Position = UDim2.new(1, -270, 1, -70)}):Play()
        task.delay(3.5, function() notif:Destroy() end)
    end

    return self
end

return InfinityUI
