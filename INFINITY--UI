    return frame
end

-- ============================================
-- FUNÇÃO: Criar Botão
-- ============================================
function InfinityUI.CreateButton(parent, text, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -20, 0, 45)
    button.Position = UDim2.new(0, 10, 0, 0)
    button.Text = text
    button.TextColor3 = parent.currentTheme.Text
    button.BackgroundColor3 = parent.currentTheme.Button
    button.Font = Enum.Font.GothamBold
    button.TextSize = 16
    button.BorderSizePixel = 0
    button.Parent = parent.container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button
    
    -- Efeito de clique
    button.MouseButton1Down:Connect(function()
        button.BackgroundColor3 = parent.currentTheme.ButtonHover
    end)
    
    button.MouseButton1Up:Connect(function()
        button.BackgroundColor3 = parent.currentTheme.Button
    end)
    
    button.MouseButton1Click:Connect(callback)
    
    return button
end

