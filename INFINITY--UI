    trilho.Position = UDim2.new(0, InfinityUI.Estilo.Padding, 0, 42)
    trilho.BackgroundColor3 = InfinityUI.Cores.SliderTrilho
    trilho.BorderSizePixel = 0
    trilho.Parent = frame
    
    criarCanto(trilho, 2)
    
    -- Parte preenchida do slider
    local preenchido = Instance.new("Frame")
    local porcentagem = (valorInicial - min) / (max - min)
