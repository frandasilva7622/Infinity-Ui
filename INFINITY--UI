-- ============================================
-- FUNÇÃO: Aplicar Tema
-- ============================================
function InfinityUI.SetTheme(themeName)
    if InfinityUI.Themes[themeName] then
        currentTheme = InfinityUI.Themes[themeName]
        InfinityUI.Settings.Theme = themeName
        -- Atualizar todas as janelas abertas com o novo tema
        for _, window in pairs(openWindows) do
            if window.UpdateTheme then
                window:UpdateTheme(currentTheme)
            end
        end
    end
end

-- ============================================
-- FUNÇÃO: Criar Janela
-- ============================================
function InfinityUI.CreateWindow(config)
    config = config or {}
    local title = config.Title or "Infinity UI"
    local size = config.Size or UDim2.new(0, 400, 0, 500)
    local theme = config.Theme and InfinityUI.Themes[config.Theme] or currentTheme
    
    -- Criar GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "InfinityUI_" .. title
    screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    
    -- Fundo escuro
    local darkBg = Instance.new("Frame")
    darkBg.Size = UDim2.new(1, 0, 1, 0)
    darkBg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    darkBg.BackgroundTransparency = 0.5
    darkBg.Parent = screenGui
    
    -- Janela principal
    local window = Instance.new("Frame")
    window.Size = size
    window.Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2)
    window.BackgroundColor3 = theme.Background
    window.BorderSizePixel = 0
    window.ClipsDescendants = true
    window.Parent = screenGui
    
    -- Cantos arredondados
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = window
    
    -- Barra de título
    local topbar = Instance.new("Frame")
    topbar.Size = UDim2.new(1, 0, 0, 45)
    topbar.BackgroundColor3 = theme.Topbar
    topbar.BorderSizePixel = 0
    topbar.Parent = window
    
    local topbarCorner = Instance.new("UICorner")
    topbarCorner.CornerRadius = UDim.new(0, 12)
    topbarCorner.Parent = topbar
    
    -- Título
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -50, 1, 0)
    titleLabel.Position = UDim2.new(0, 15, 0, 0)
    titleLabel.Text = title
    titleLabel.TextColor3 = theme.Text
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 18
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topbar
    
    -- Botão fechar
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 32, 0, 32)
    closeBtn.Position = UDim2.new(1, -42, 0, 6.5)
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = theme.Text
    closeBtn.BackgroundColor3 = theme.ToggleOff
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 18
    closeBtn.BorderSizePixel = 0
    closeBtn.Parent = topbar
    
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 8)
    closeCorner.Parent = closeBtn
    
    -- Área de conteúdo com scroll
    local container = Instance.new("ScrollingFrame")
    container.Size = UDim2.new(1, 0, 1, -45)
    container.Position = UDim2.new(0, 0, 0, 45)
    container.BackgroundTransparency = 1
    container.CanvasSize = UDim2.new(0, 0, 0, 0)
    container.ScrollBarThickness = 4
    container.ScrollBarImageColor3 = theme.Border
    container.Parent = window
    
    -- Layout automático
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = container
    
    -- Atualizar canvas size
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        container.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)
    
    -- Sistema de arrastar
    local dragging = false
    local dragStart, startPos
    
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or 
           input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = window.Position
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging then
            if input.UserInputType == Enum.UserInputType.Touch or
               input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - dragStart
                window.Position = UDim2.new(
                    startPos.X.Scale,
                    startPos.X.Offset + delta.X,
                    startPos.Y.Scale,
                    startPos.Y.Offset + delta.Y
                )
            end
        end
    end)
    
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or
           input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- Fechar janela
    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
        openWindows[window] = nil
    end)
    
    -- Objeto da janela
    local windowObj = {
        container = container,
        layout = layout,
        screenGui = screenGui,
        window = window,
        titleLabel = titleLabel,
        topbar = topbar,
        darkBg = darkBg,
        currentTheme = theme,
        
        -- Função para atualizar tema
        UpdateTheme = function(self, newTheme)
            self.currentTheme = newTheme
            self.window.BackgroundColor3 = newTheme.Background
            self.topbar.BackgroundColor3 = newTheme.Topbar
            self.titleLabel.TextColor3 = newTheme.Text
            closeBtn.BackgroundColor3 = newTheme.ToggleOff
            closeBtn.TextColor3 = newTheme.Text
            container.ScrollBarImageColor3 = newTheme.Border
        end,
        
        -- Fechar janela
        Close = function(self)
            self.screenGui:Destroy()
        end,
        
        -- Definir título
        SetTitle = function(self, newTitle)
            self.titleLabel.Text = newTitle
        end
    }
    
    openWindows[windowObj] = true
    return windowObj
end

