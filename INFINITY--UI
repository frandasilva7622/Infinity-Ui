-- INFINITY UI ULTRA V3

--// Serviços
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")
local HttpService = game:GetService("HttpService")

local InfinityUI = {}
InfinityUI.__index = InfinityUI

--// Tema completo
InfinityUI.Theme = {
    Background = Color3.fromRGB(18,18,22),
    Secondary = Color3.fromRGB(28,28,32),
    Accent = Color3.fromRGB(140,70,255),
    Text = Color3.fromRGB(255,255,255),
    Stroke = Color3.fromRGB(60,60,70)
}

InfinityUI.Registry = {}

function InfinityUI:Track(obj,type)
    table.insert(self.Registry,{Instance=obj,Type=type})
end

function InfinityUI:SetTheme(t)
    for k,v in pairs(t) do self.Theme[k]=v end

    for _,v in pairs(self.Registry) do
        if v.Type=="BG" then v.Instance.BackgroundColor3=self.Theme.Background end
        if v.Type=="SEC" then v.Instance.BackgroundColor3=self.Theme.Secondary end
        if v.Type=="TXT" then v.Instance.TextColor3=self.Theme.Text end
        if v.Type=="ACC" then v.Instance.BackgroundColor3=self.Theme.Accent end
    end
end

--// WINDOW
function InfinityUI:CreateWindow(title)
    local self=setmetatable({},InfinityUI)

    local gui=Instance.new("ScreenGui",game.CoreGui)

    local blur=Instance.new("BlurEffect",Lighting)
    blur.Size=15

    local main=Instance.new("Frame",gui)
    main.Size=UDim2.new(0,500,0,320)
    main.Position=UDim2.new(0.5,-250,0.5,-160)
    main.BackgroundColor3=self.Theme.Background
    self:Track(main,"BG")
    Instance.new("UICorner",main).CornerRadius=UDim.new(0,12)

    -- resize
    local resizing=false
    local resizeHandle=Instance.new("Frame",main)
    resizeHandle.Size=UDim2.new(0,15,0,15)
    resizeHandle.Position=UDim2.new(1,-15,1,-15)

    resizeHandle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then resizing=true end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if resizing and i.UserInputType==Enum.UserInputType.MouseMovement then
            local delta=i.Position
            main.Size=UDim2.new(0,delta.X,0,delta.Y)
        end
    end)

    resizeHandle.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false end
    end)

    -- topbar
    local top=Instance.new("Frame",main)
    top.Size=UDim2.new(1,0,0,32)
    top.BackgroundColor3=self.Theme.Secondary
    self:Track(top,"SEC")

    local titleLabel=Instance.new("TextLabel",top)
    titleLabel.Text=title
    titleLabel.Size=UDim2.new(1,-120,1,0)
    titleLabel.Position=UDim2.new(0,10,0,0)
    titleLabel.BackgroundTransparency=1
    titleLabel.TextColor3=self.Theme.Text
    self:Track(titleLabel,"TXT")

    local close=Instance.new("TextButton",top)
    close.Text="X"
    close.Size=UDim2.new(0,30,1,0)
    close.Position=UDim2.new(1,-30,0,0)

    local min=Instance.new("TextButton",top)
    min.Text="-"
    min.Size=UDim2.new(0,30,1,0)
    min.Position=UDim2.new(1,-60,0,0)

    -- drag
    local drag=false; local dragStart; local startPos
    top.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; dragStart=i.Position; startPos=main.Position
        end
    end)

    top.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local delta=i.Position-dragStart
            main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
        end
    end)

    -- sidebar
    local sidebar=Instance.new("Frame",main)
    sidebar.Size=UDim2.new(0,130,1,-32)
    sidebar.Position=UDim2.new(0,0,0,32)
    sidebar.BackgroundColor3=self.Theme.Secondary

    local content=Instance.new("Frame",main)
    content.Size=UDim2.new(1,-130,1,-32)
    content.Position=UDim2.new(0,130,0,32)

    -- floating
    min.MouseButton1Click:Connect(function()
        main.Visible=false
        local f=Instance.new("TextButton",gui)
        f.Size=UDim2.new(0,50,0,50)
        f.Position=UDim2.new(0,20,0.5,0)
        f.Text="UI"
        f.MouseButton1Click:Connect(function()
            main.Visible=true; f:Destroy()
        end)
    end)

    close.MouseButton1Click:Connect(function()
        blur:Destroy(); gui:Destroy()
    end)

    function self:Notify(text)
        local n=Instance.new("TextLabel",gui)
        n.Size=UDim2.new(0,200,0,50)
        n.Position=UDim2.new(1,-220,1,-60)
        n.Text=text
        wait(2)
        n:Destroy()
    end

    function self:CreateTab(name)
        local btn=Instance.new("TextButton",sidebar)
        btn.Size=UDim2.new(1,0,0,30)
        btn.Text=name

        local page=Instance.new("Frame",content)
        page.Size=UDim2.new(1,0,1,0)
        page.Visible=false

        local layout=Instance.new("UIListLayout",page)
        layout.Padding=UDim.new(0,6)

        btn.MouseButton1Click:Connect(function()
            for _,v in pairs(content:GetChildren()) do
                if v:IsA("Frame") then v.Visible=false end
            end
            page.Visible=true
        end)

        local Tab={}

        function Tab:CreateButton(t,cb)
            local b=Instance.new("TextButton",page)
            b.Size=UDim2.new(1,0,0,35)
            b.Text=t
            b.MouseButton1Click:Connect(cb)
        end

        function Tab:CreateToggle(t,cb)
            local s=false
            local b=Instance.new("TextButton",page)
            b.Size=UDim2.new(1,0,0,35)
            b.Text=t.." : OFF"
            b.MouseButton1Click:Connect(function()
                s=not s
                b.Text=t.." : "..(s and "ON" or "OFF")
                cb(s)
            end)
        end

        function Tab:CreateTextbox(t,cb)
            local box=Instance.new("TextBox",page)
            box.Size=UDim2.new(1,0,0,35)
            box.PlaceholderText=t
            box.FocusLost:Connect(function()
                cb(box.Text)
            end)
        end

        function Tab:CreateKeybind(t,key,cb)
            UserInputService.InputBegan:Connect(function(i)
                if i.KeyCode==key then cb() end
            end)
        end

        function Tab:CreateSlider(t,min,max,cb)
            local val=min
            local f=Instance.new("Frame",page)
            f.Size=UDim2.new(1,0,0,40)

            local lbl=Instance.new("TextLabel",f)
            lbl.Size=UDim2.new(1,0,0,20)
            lbl.Text=t..":"..val

            local bar=Instance.new("Frame",f)
            bar.Size=UDim2.new(1,0,0,10)
            bar.Position=UDim2.new(0,0,0,25)

            local fill=Instance.new("Frame",bar)
            fill.Size=UDim2.new(0,0,1,0)

            bar.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    local pos=(i.Position.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X
                    val=math.floor((max-min)*pos+min)
                    fill.Size=UDim2.new(pos,0,1,0)
                    lbl.Text=t..":"..val
                    cb(val)
                end
            end)
        end

        function Tab:CreateColorPicker(t,cb)
            local b=Instance.new("TextButton",page)
            b.Size=UDim2.new(1,0,0,35)
            b.Text=t
            b.MouseButton1Click:Connect(function()
                local c=Color3.fromRGB(math.random(0,255),math.random(0,255),math.random(0,255))
                cb(c)
            end)
        end

        return Tab
    end

    return self
end

return InfinityUI
